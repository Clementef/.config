#------------------------
#	power

super + shift + q
	s_power

#------------------------
#	software

super + space
	dmenu_run -p "Run:"

super + b
	brave

super + Return
	st

super + v
	st -e vim +:NERDTree

super + n
	nm-connection-editor

super + g
	fehbg

super + x
	flameshot gui

super + shift + x
	flameshot screen

super + c
    s_runcmd

super + r
	s_reloadprogram
#------------------------
#	notifications

alt + n
	notify-send -u low "Wifi" "$(s_wifiscan)"

alt + y
	notify-send -u low "Storage" "$(s_storage)"

alt + c
	notify-send -u low "Dracula" "$(s_dracula)"

alt + l
	notify-send -u low "Sessions" "$(s_sessionlist)"
